# LegalShield-jp environment template.
# Copy to .env (local dev) or .env.ec2 (production) and edit.

APP_ENV=local
APP_BASE_URL=http://localhost:8090
SITE_BASE_URL=https://legalshield.jp

# ─── Database ────────────────────────────────────────────────
# Local dev (own postgres in docker-compose.local.yml):
DATABASE_URL=postgresql+asyncpg://legalshield:legalshield@postgres:5432/legalshield
DB_USER=legalshield
DB_PASSWORD=legalshield
DB_NAME=legalshield
DB_HOST_PORT=5434

# EC2 production (shared postgres with hiiforest, separate database):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:5432/legalshield

# ─── Service ports ───────────────────────────────────────────
API_HOST_PORT=8090
FRONTEND_HOST_PORT=8092

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8092,http://127.0.0.1:8092,https://legalshield.jp

# ─── Ingest (no API keys required for the public datasets) ──
# Optional override of upstream URLs; default values in ingest/common.py
HOUTERASU_CSV_URL=
NPO_CSV_URL=
N03_SHAPEFILE_URL=
ESTAT_API_APP_ID=

# ─── AWS (only needed if you push tiles to S3) ──────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_S3_BUCKET=legalshield-tiles

# ─── Privacy ────────────────────────────────────────────────
# Random seed offset (meters) for incident-report obfuscated geom.
# Lower bound 100 m, upper bound 300 m (per spec).
INCIDENT_OBFUSCATE_MIN_M=100
INCIDENT_OBFUSCATE_MAX_M=300
