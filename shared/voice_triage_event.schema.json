{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legalshield.local/schemas/voice_triage_event_v1.json",
  "title": "VoiceTriageEvent v1",
  "description": "iOS LegalShield app から GIS API / 管理者ダッシュ / フィードバック訓練 へ送る単一統一形式。シリアライズは JSON、暗号化は AES-GCM、転送は HTTPS POST。",
  "type": "object",
  "required": ["schema_version", "event_id", "device_id", "timestamp", "recording_mode", "transcript", "triage", "anonymization_level"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "1 録音セッション = 1 event_id"
    },
    "device_id": {
      "type": "string",
      "description": "端末識別（identifierForVendor）。anonymization=full では (anonymized) に置換"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "case_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "既存案件への紐付け（あれば）"
    },

    "recording_mode": {
      "type": "string",
      "enum": ["standby", "incident", "continuous", "evidence"]
    },
    "duration_sec": {
      "type": "number",
      "minimum": 0
    },
    "audio_segment_count": {
      "type": "integer",
      "description": "continuous モードで何チャンクに分割したか"
    },
    "audio_sha256_chain": {
      "type": "array",
      "description": "各音声チャンクの SHA-256（証拠改ざん検出）",
      "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },

    "transcript": {
      "type": "object",
      "required": ["full_text", "detected_languages", "model"],
      "properties": {
        "full_text": { "type": "string" },
        "detected_languages": {
          "type": "array",
          "items": { "type": "string", "minLength": 2, "maxLength": 5 }
        },
        "primary_language": { "type": "string" },
        "model": { "type": "string", "examples": ["openai_whisper-base", "legalshield_v1"] },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end", "text"],
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" },
              "text": { "type": "string" },
              "confidence": { "type": ["number", "null"] },
              "language": { "type": ["string", "null"] }
            }
          }
        },
        "nonverbal_events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end", "label"],
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" },
              "label": {
                "type": "string",
                "enum": ["crying", "sobbing", "whimper", "screaming", "heavy_breathing",
                        "sigh", "wail", "gasp", "whispering", "silence", "panting", "other"]
              },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },

    "triage": {
      "type": "object",
      "required": ["category", "urgency", "confidence"],
      "properties": {
        "category": {
          "type": "string",
          "description": "data/case_taxonomy/taxonomy_v1.json の categories[].id と一致"
        },
        "category_alternatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "urgency": { "type": "integer", "minimum": 1, "maximum": 4 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "key_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_actions": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "engine": {
          "type": "string",
          "examples": ["mlx-phi-3.5-mini-4bit", "rule-based-fallback", "bedrock-claude-3.5-sonnet-v2"]
        },
        "needs_cloud_review": { "type": "boolean" },
        "cloud_review_summary": { "type": ["string", "null"] }
      }
    },

    "location": {
      "type": ["object", "null"],
      "description": "anonymization=full なら null",
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "accuracy_m": { "type": "number" },
        "altitude_m": { "type": ["number", "null"] },
        "h3_index": { "type": ["string", "null"], "description": "H3 hexagon index (resolution 9)" }
      }
    },

    "speaker_metadata": {
      "type": "object",
      "properties": {
        "estimated_age_group": {
          "type": ["string", "null"],
          "enum": ["child", "teen", "adult", "elderly", null]
        },
        "estimated_emotion": {
          "type": ["string", "null"],
          "enum": ["fear", "anger", "sadness", "panic", "calm", "uncertain", null]
        },
        "voice_volume_dbfs": { "type": ["number", "null"] }
      }
    },

    "anonymization_level": {
      "type": "string",
      "enum": ["none", "partial", "full"]
    },

    "encryption": {
      "type": "object",
      "properties": {
        "algorithm": { "type": "string", "examples": ["AES-GCM-256"] },
        "key_id": { "type": "string", "description": "Keychain 上の鍵 ID（鍵自体は含めない）" }
      }
    },

    "remote_dispatch": {
      "type": "object",
      "description": "受信側の処理結果。送信時は空、管理者ダッシュが書込む",
      "properties": {
        "received_at": { "type": ["string", "null"], "format": "date-time" },
        "assigned_handler": { "type": ["string", "null"] },
        "handler_action": {
          "type": ["string", "null"],
          "enum": ["acknowledge", "escalate_police", "escalate_jidoso", "request_continued_recording",
                  "send_message_to_user", "close_no_action", null]
        },
        "instruction_to_user": { "type": ["string", "null"] }
      }
    },

    "feedback": {
      "type": "object",
      "description": "事後の訓練フィードバック",
      "properties": {
        "correct_category": { "type": ["string", "null"] },
        "correct_urgency": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
        "transcript_correction": { "type": ["string", "null"] },
        "annotated_by": { "type": ["string", "null"] },
        "annotated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },

    "audit_chain_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "前イベントの SHA-256（チェーン検証用）"
    }
  }
}
